<Project>
  <!--
    Build-isolation barrier for git submodules under external/. Stops the
    Directory.Build.props inheritance walk here so the repo root's props
    (TreatWarningsAsErrors, AnalysisLevel, net10.0-only TargetFramework,
    RootNamespace override, …) never leak into a submodule's projects, which
    build under their own settings. Deliberately empty; submodules that carry
    their own Directory.Build.props (engineered-wood does, under src/) are found
    first anyway — this guards the case where they don't.
  -->
</Project>
